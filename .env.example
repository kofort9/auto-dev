# Target repository for bugbot scanning and nightshift processing
TARGET_REPO=~/Repos/your-target-repo

# Nightshift state directory (state file, lock, logs, run artifacts)
STATE_DIR=~/.auto-dev

# Bugbot state directory
BUGBOT_STATE=~/.bugbot

# Bugbot scan target (defaults to TARGET_REPO if unset)
# SCAN_ROOT=~/Repos/your-target-repo

# Bugbot source directory
# BUGBOT_ROOT=~/Repos/auto-dev/bugbot
