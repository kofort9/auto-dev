@@ -0,0 +1,12 @@
+import type { NonprofitProfile } from "./types.js";
+
+export function calculateScore(profile: NonprofitProfile): number {
+  let score = 0;
+  if (profile.name) score += 10;
+  if (profile.ein) score += 20;
+  if (profile.mission) score += 30;
+  return Math.min(score, 100);
+}

diff --git a/src/domain/nonprofit/score-thresholds.ts b/src/domain/nonprofit/score-thresholds.ts
new file mode 100644
index 0000000..2222222
--- /dev/null
+++ b/src/domain/nonprofit/score-thresholds.ts
@@ -0,0 +1,14 @@
+export const THRESHOLDS = {
+  excellent: 90,
+  good: 70,
+  fair: 50,
+  poor: 30,
+} as const;
+
+export function getScoreTier(score: number): string {
+  if (score >= THRESHOLDS.excellent) return "excellent";
+  if (score >= THRESHOLDS.good) return "good";
+  if (score >= THRESHOLDS.fair) return "fair";
+  return "poor";
+}

